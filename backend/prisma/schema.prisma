// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String   // hashed
  name        String?
  avatar      String?  // URL
  role        String?  // 目标岗位
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  resumes     Resume[]
  interviews  InterviewSession[]
  trainingTasks TrainingTask[]
  settings    UserSettings?

  @@map("users")
}

model Resume {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  fileUrl       String   // 文件存储路径或 URL
  fileType      String   // pdf, docx, txt
  fileSize      Int      // bytes
  fileName      String

  content       String?  // OCR 或解析后的文本内容
  skills        String[] // JSON array
  experience    String?  // JSON string
  projects      String?  // JSON string

  isDefault     Boolean  @default(false)
  isParsed      Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions      InterviewSession[]  // 添加反向关系

  @@map("resumes")
}

model InterviewSession {
  id              String          @id @default(uuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  resumeId        String?         // 关联的简历
  resume          Resume?         @relation(fields: [resumeId], references: [id])

  position        String          // 目标岗位
  company         String?         // 目标公司
  interviewType   String          // technical, project, hr, stress
  difficulty      Int             // 1-5
  focusAreas      String[]        // 关注领域数组

  status          InterviewStatus @default(pending) // pending, in_progress, completed, aborted
  currentStage    InterviewStage  @default(intro) // intro, project, technical, scenario, summary
  mode            String          @default("text") // text or video
  videoUrl        String?         // 录像文件存储路径/URL

  startTime       DateTime?
  endTime         DateTime?
  duration        Int?            // 秒数

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // 关联数据
  messages        InterviewMessage[]
  report          Report?

  @@map("interview_sessions")
}

enum InterviewStatus {
  pending
  in_progress
  completed
  aborted
}

enum InterviewStage {
  intro      // 自我介绍
  project    // 项目深挖
  technical  // 技术考察
  scenario   // 场景追问
  summary    // 总结
}

model InterviewMessage {
  id          String        @id @default(uuid())
  sessionId   String
  session     InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  role        MessageRole   // ai or user
  content     String        // 消息内容
  questionId  String?       // 如果是回答，关联的问题 ID

  isFollowup  Boolean       @default(false)
  parentMsgId String?       // 追问的父消息 ID

  score       Float?        // AI 评分
  feedback    String?       // AI 反馈
  audioUrl      String?         // AI 语音片段存储URL
  sttConfidence Float?          // STT 识别置信度
  duration      Int?            // 音频时长(ms)

  createdAt   DateTime      @default(now())

  @@index([sessionId])
  @@map("interview_messages")
}

enum MessageRole {
  ai
  user
}

model Report {
  id            String        @id @default(uuid())
  sessionId     String        @unique
  session       InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // 总体评价
  totalScore    Float         // 0-100
  summary       String        // 总体评价文本
  percentile    Int?          // 百分位

  // 维度评分
  technicalScore   Float?     // 技术能力
  expressionScore  Float?     // 表达能力
  projectScore     Float?     // 项目深度
  stabilityScore   Float?     // 稳定性

  // 分析内容
  strengths     String[]      // JSON array
  weaknesses    String[]      // JSON array
  suggestions   String[]      // JSON array

  weakTags      String[]      // 弱点标签

  // 推荐训练
  recommendedTopics String[]  // JSON array

  status        ReportStatus  @default(pending) // pending, ready, failed
  retryCount    Int           @default(0)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  trainingTasks TrainingTask[]  // 添加反向关系

  @@map("reports")
}

enum ReportStatus {
  pending
  ready
  failed
}

model TrainingTask {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  reportId      String?       // 来源报告
  report        Report?       @relation(fields: [reportId], references: [id])

  title         String
  description   String
  weakTag       String        // 弱点标签

  status        TaskStatus    @default(todo) // todo, in_progress, done
  startedAt     DateTime?
  completedAt   DateTime?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId])
  @@index([status])
  @@map("training_tasks")
}

enum TaskStatus {
  todo
  in_progress
  done
}

model UserSettings {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // AI 面试官偏好
  aiPersonality String   @default("professional") // professional, encouraging, stress
  aiSpeed       String   @default("normal")       // slow, normal, fast
  feedbackLevel String   @default("medium")       // short, medium, deep

  // 通用设置
  language      String   @default("zh")
  darkMode      Boolean  @default(false)
  notifications Boolean  @default(true)
  autoSave      Boolean  @default(true)

  defaultRole   String?  // 默认目标岗位

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("user_settings")
}

model EventLog {
  id            String   @id @default(uuid())
  userId        String?  // 可能是未登录用户
  sessionId     String?  // 事件关联的面试会话 ID

  eventName     String   // 事件名称
  eventData     String   // JSON string

  timestamp     DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([eventName, timestamp])
  @@map("event_logs")
}
