    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.34.0",
    "pdf-parse": "^1.1.4",
    "prisma": "^5.11.0",
    "socket.io": "^4.8.3",
    "typescript": "^5.8.2",
    "uuid": "^9.0.1",
    "ws": "^8.20.0",
    "zod": "^3.22.4"
  },
